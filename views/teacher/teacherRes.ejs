<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Teacher Registration</title>
    <style>
        body {
            font-family: 'Manrope', sans-serif;
        }
    </style>
</head>

<body class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-100 via-white to-purple-100">
    <div class="w-full max-w-lg bg-white rounded-2xl shadow-xl p-10">
        <h1 class="text-3xl font-bold text-center text-gray-800">
            Teacher Registration
        </h1>
        <p class="text-center text-gray-500 mt-2">
            Create your teacher account
        </p>
        <form action="/registerT" method="POST" class="mt-8 space-y-6">

            <div>
                <label class="block text-sm font-semibold text-gray-700">
                    Full Name
                </label>
                <input type="text" name="name" required placeholder="Enter your full name"
                    class="w-full mt-2 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-400 focus:outline-none" />
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700">
                    Email Address
                </label>
                <input type="email" name="email" required placeholder="Enter your email"
                    class="w-full mt-2 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-400 focus:outline-none" />
                <p class="text-xs text-gray-500 mt-1">
                    We'll never share your email with anyone.
                </p>
            </div>

            <div
                <label class="block text-sm font-semibold text-gray-700">
                    Teacher ID
                </label>
                <input type="text" name="t_id" required placeholder="Enter teacher ID"
                    class="w-full mt-2 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-400 focus:outline-none" />
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700">
                    Password
                </label>
                <input type="password" id="password" name="password" required placeholder="Create password"
                    class="w-full mt-2 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-400 focus:outline-none" />
                <div class="flex items-center mt-2 gap-2 text-sm">
                    <input type="checkbox" onclick="togglePassword()" class="accent-indigo-600">
                    <span class="text-gray-600">
                        Show Password
                    </span>
                </div>
            </div>
   
            <button type="submit"
                class="w-full bg-indigo-600 text-white py-3 rounded-lg font-semibold hover:bg-indigo-700 transition">
                Create Account
            </button>
    
            <p class="text-center text-sm text-gray-500">
                Already have an account?
                <a href="/login" class="text-indigo-600 font-medium hover:underline">
                    Login
                </a>
            </p>
        </form>
    </div>
    <script>
        function togglePassword() {
            const password = document.getElementById("password");
            if (password.type === "password") {
                password.type = "text";
            } else {
                password.type = "password";
            }
        }
    </script>
</body>

</html>