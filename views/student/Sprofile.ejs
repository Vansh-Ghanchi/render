<%- include('../include/_Shead') %>

    <div class="flex-1">

        <header class="flex justify-between items-center bg-white shadow p-4">
            <button id="menuBtn" class="md:hidden text-2xl">☰</button>

            <h1 class="text-xl font-semibold">Student Profile</h1>

            <div class="flex items-center gap-4">
                <input type="text" placeholder="Search..." class="border rounded-lg px-3 py-1 w-40 md:w-64">

                <img src="https://picsum.photos/300/300" class="rounded-full w-10 h-10 object-cover">
            </div>
        </header>


        <main class="p-6 bg-gray-100 min-h-screen space-y-6">

            <section class="bg-white rounded-xl shadow p-6">

                <div class="flex flex-col md:flex-row gap-6 items-center md:items-start">

                    <div class="w-32 h-32 rounded-full overflow-hidden border">
                        <img src="https://picsum.photos/300/300" class="w-full h-full object-cover">
                    </div>

                    <div class="flex-1 space-y-2 text-center md:text-left">

                        <h2 class="text-2xl font-semibold text-gray-800">
                            <%= student.name %>
                        </h2>

                        <p class="text-gray-600">
                            Enrollment No: <span class="font-medium">
                                <%= student.enroll %>
                            </span>
                        </p>

                        <p class="text-gray-600">
                            Email: <span class="font-medium">
                                <%= student.email %>
                            </span>
                        </p>

                        <p class="text-gray-600">
                            Department: <span class="font-medium">
                                <%= student.name %>
                            </span>
                        </p>

                        <p class="text-gray-600">
                            Semester: <span class="font-medium">
                                <%= result.sem %>
                            </span>
                        </p>

                    </div>

                    <div class="flex flex-col gap-3">

                        <button class="bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg">
                            Edit Profile
                        </button>

                        <button class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg">
                            Change Password
                        </button>

                    </div>

                </div>

            </section>
            <section class="grid md:grid-cols-3 gap-6">

                <div class="bg-white p-5 rounded-xl shadow text-center">
                    <p class="text-gray-500">Current Semester</p>
                    <h3 class="text-2xl font-bold text-blue-600">
                        <%= result.sem %>
                    </h3>
                </div>

                <div class="bg-white p-5 rounded-xl shadow text-center">
                    <p class="text-gray-500">Total Credits</p>
                    <h3 class="text-2xl font-bold text-green-600">
                        <%= result.creditsEarned %>
                    </h3>
                </div>

                <div class="bg-white p-5 rounded-xl shadow text-center">
                    <p class="text-gray-500">Overall GPA</p>
                    <h3 class="text-2xl font-bold text-purple-600">
                        <%= result.CGPA %>
                    </h3>
                </div>

            </section>
            <section class="bg-white p-6 rounded-xl shadow">

                <h2 class="text-lg font-semibold mb-4">
                    Contact Information
                </h2>

                <div class="grid md:grid-cols-2 gap-4 text-gray-700">

                    <p>
                        Phone: <span class="font-medium">+91 9876543210</span>
                    </p>

                    <p>
                        Address: <span class="font-medium">Ahmedabad, Gujarat</span>
                    </p>

                    <p>
                        Date of Birth: <span class="font-medium">10 Jan 2002</span>
                    </p>

                    <p>
                        Admission Year: <span class="font-medium">2022</span>
                    </p>

                </div>

            </section>

        </main>

    </div>

    <%- include('../include/_Sfoot') %>