<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <title>Student Management System</title>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>

</head>
<script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
<script>
    AOS.init({
        duration: 1000,
        once: true
    });
</script>

<body class="bg-gray-50 text-gray-800" style='font-family: "Poppins", sans-serif;'>

    <!-- NAVBAR -->
    <header class="sticky top-0 backdrop-blur-lg bg-white/70 border-b border-gray-200 z-50">
        <nav class="max-w-7xl mx-auto flex items-center justify-between p-6">
            <h1 class="text-xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
                SMS Portal
            </h1>
            <div class="hidden md:flex gap-10 text-sm font-medium">
                <a href="/" class="hover:text-indigo-600 transition">Home</a>
                <a href="/result" class="hover:text-indigo-600 transition">Results</a>
                <a href="/dashboard" class="hover:text-indigo-600 transition">Dashboard</a>
            </div>
            <a href="/login" class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 transition">
                Login
            </a>
        </nav>
    </header>
    <!-- HERO -->
    <section class="relative overflow-hidden py-32">
        <div class="absolute inset-0 -z-10 bg-gradient-to-br from-indigo-100 via-white to-purple-100"></div>
        <div class="absolute -top-40 -left-40 w-96 h-96 bg-indigo-400 rounded-full blur-3xl opacity-20 animate-pulse">
        </div>
        <div class="absolute top-40 -right-40 w-96 h-96 bg-purple-400 rounded-full blur-3xl opacity-20 animate-pulse">
        </div>
        <div class="max-w-6xl mx-auto text-center px-6">
            <h1 class="text-6xl font-bold leading-tight">
                Modern
                <span class="bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
                    Student Management
                </span>
                Platform
            </h1>
            <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
                Manage students, upload results, and access academic data through a secure and modern system.
            </p>
            <div class="mt-10 flex justify-center gap-4 flex-wrap">
                <a href="/student"
                    class="bg-indigo-600 text-white px-7 py-3 rounded-xl shadow-lg hover:shadow-indigo-300/50 hover:scale-105 transition">
                    Register Student
                </a>
                <a href="/teacher"
                    class="border px-7 py-3 rounded-xl shadow-lg hover:bg-gray-200 hover:scale-105 transition">
                    Register Teacher
                </a>
            </div>
        </div>
    </section>
    <!-- FEATURES -->
    <section class="py-24">
        <div class="max-w-7xl mx-auto px-6">
            <h2 class="text-center text-indigo-600 font-semibold">
                Features
            </h2>
            <h3 class="text-center text-4xl font-bold mt-2">
                Academic Management Platform
            </h3>
            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mt-16">
                <div
                    class="group bg-white p-8 rounded-xl shadow-md hover:shadow-2xl hover:-translate-y-2 transition duration-300">
                    <div class="text-4xl mb-4 group-hover:scale-110 transition">🎓</div>
                    <h3 class="font-semibold text-lg">
                        Student Portal
                    </h3>
                    <p class="mt-2 text-gray-600">
                        Students can login securely and view semester results and academic history.
                    </p>
                </div>
                <div
                    class="group bg-white p-8 rounded-xl shadow-md hover:shadow-2xl hover:-translate-y-2 transition duration-300">
                    <div class="text-4xl mb-4 group-hover:scale-110 transition">👨‍🏫</div>
                    <h3 class="font-semibold text-lg">
                        Teacher Panel
                    </h3>
                    <p class="mt-2 text-gray-600">
                        Teachers upload marks, manage subjects and update student records.
                    </p>
                </div>
                <div
                    class="group bg-white p-8 rounded-xl shadow-md hover:shadow-2xl hover:-translate-y-2 transition duration-300">
                    <div class="text-4xl mb-4 group-hover:scale-110 transition">
                        🔐</div>
                    <h3 class="font-semibold text-lg">
                        Secure Authentication
                    </h3>
                    <p class="mt-2 text-gray-600">
                        JWT authentication and password hashing keep user data secure.
                    </p>
                </div>
                <div
                    class="group bg-white p-8 rounded-xl shadow-md hover:shadow-2xl hover:-translate-y-2 transition duration-300">
                    <div class="text-4xl mb-4 group-hover:scale-110 transition">
                        📊</div>
                    <h3 class="font-semibold text-lg">
                        Result Management
                    </h3>
                    <p class="mt-2 text-gray-600">
                        Administrators manage academic records and publish results.
                    </p>
                </div>
            </div>
        </div>
    </section>
    <!-- HOW IT WORKS -->
    <section class="bg-white py-24">
        <div class="max-w-7xl mx-auto px-6">
            <h2 class="text-center text-4xl font-bold">
                How It Works
            </h2>
            <div class="grid md:grid-cols-3 gap-10 mt-16 text-center">
                <div>
                    <div class="text-indigo-600 text-5xl font-bold">1</div>
                    <h3 class="mt-4 font-semibold text-xl">
                        Register
                    </h3>
                    <p class="text-gray-600 mt-2">
                        Students and teachers create secure accounts.
                    </p>
                </div>
                <div>
                    <div class="text-indigo-600 text-5xl font-bold">2</div>
                    <h3 class="mt-4 font-semibold text-xl">
                        Upload Marks
                    </h3>
                    <p class="text-gray-600 mt-2">
                        Teachers manage subjects and upload results.
                    </p>
                </div>
                <div>
                    <div class="text-indigo-600 text-5xl font-bold">3</div>
                    <h3 class="mt-4 font-semibold text-xl">
                        View Results
                    </h3>
                    <p class="text-gray-600 mt-2">
                        Students login anytime to check semester results.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- SYSTEM PREVIEW -->

    <section class="py-28 bg-gradient-to-b from-white to-indigo-50">
        <div class="max-w-7xl mx-auto px-6">
            <h2 class="text-center text-4xl font-bold text-gray-900">
                Simple & Powerful Dashboard
            </h2>
            <p class="text-center text-gray-600 mt-4 max-w-2xl mx-auto">
                Manage students, upload marks and track results through an intuitive dashboard designed for modern
                academic systems.
            </p>
            <div class="mt-16 relative">
                <!-- glow background -->
                <div class="absolute inset-0 bg-indigo-300 blur-3xl opacity-20 rounded-3xl"></div>
                <!-- dashboard card -->
                <div class="relative bg-white rounded-2xl shadow-2xl p-10 grid md:grid-cols-3 gap-8">
                    <!-- card 1 -->
                    <div class="p-6 bg-indigo-50 rounded-xl">
                        <h3 class="font-semibold text-lg">Student Records</h3>
                        <p class="text-gray-600 mt-2 text-sm">
                            Easily manage enrollment, subjects and academic details.
                        </p>
                    </div>
                    <!-- card 2 -->
                    <div class="p-6 bg-indigo-50 rounded-xl">
                        <h3 class="font-semibold text-lg">Upload Results</h3>
                        <p class="text-gray-600 mt-2 text-sm">
                            Teachers can securely upload semester marks and update records.
                        </p>
                    </div>
                    <!-- card 3 -->
                    <div class="p-6 bg-indigo-50 rounded-xl">
                        <h3 class="font-semibold text-lg">Result Analytics</h3>
                        <p class="text-gray-600 mt-2 text-sm">
                            View academic performance and generate reports instantly.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- FOOTER -->
    <footer class="bg-black text-gray-400 py-12">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-10">
            <div>
                <h3 class="text-white font-semibold text-lg">
                    Student Management System
                </h3>
                <p class="mt-3">
                    Secure platform for managing academic records and results.
                </p>
            </div>
            <div>
                <h3 class="text-white font-semibold">
                    Quick Links
                </h3>
                <ul class="mt-3 space-y-2">
                    <li><a href="/">Home</a></li>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/student">Student Register</a></li>
                    <li><a href="/teacher">Teacher Register</a></li>
                </ul>
            </div>
            <div>
                <h3 class="text-white font-semibold">
                    Contact
                </h3>
                <p class="mt-3">
                    support@smsystem.com
                </p>
            </div>
        </div>
        <p class="text-center mt-10 text-gray-600">
            © 2026 Student Management System
        </p>
        <p class=" text-center mt-10 text-gray-300">
            Built using Node.js, Express, MongoDB and JWT Authentication.
        </p>
    </footer>
</body>

</html>